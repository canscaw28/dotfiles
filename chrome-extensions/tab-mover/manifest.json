{
  "manifest_version": 3,
  "name": "Tab Mover",
  "version": "1.1",
  "description": "Move tabs between Chrome windows directionally",
  "permissions": ["tabs", "system.display"],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "move-tab-left": {
      "suggested_key": { "mac": "MacCtrl+Shift+Left" },
      "description": "Move tab to window on the left"
    },
    "move-tab-right": {
      "suggested_key": { "mac": "MacCtrl+Shift+Right" },
      "description": "Move tab to window on the right"
    },
    "move-tab-up": {
      "suggested_key": { "mac": "MacCtrl+Shift+Up" },
      "description": "Move tab to window above"
    },
    "move-tab-down": {
      "suggested_key": { "mac": "MacCtrl+Shift+Down" },
      "description": "Move tab to window below"
    }
  }
}
