index 0000000..954b644
--- /dev/null
+++ b/Sources/AppBundle/command/impl/FreezeTilingCommand.swift
@@ -0,0 +1,16 @@
+import Common
+
+struct FreezeTilingCommand: Command {
+    let args: FreezeTilingCmdArgs
+    /*conforms*/ var shouldResetClosedWindowsCache = false
+
+    func run(_ env: CmdEnv, _ io: CmdIo) async throws -> Bool {
+        let newState: Bool = switch args.targetState.val {
+            case .on: true
+            case .off: false
+            case .toggle: !TrayMenuModel.shared.isTilingFrozen
+        }
+        TrayMenuModel.shared.isTilingFrozen = newState
+        return true
+    }
+}
